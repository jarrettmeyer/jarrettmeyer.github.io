---
import Layout from "../layouts/Page.astro";
import { MS_PER_YEAR } from "../consts";

const ABOUT_DESCRIPTION =
  "About Jarrett Meyer — ML engineering advisor, software architect, and the person behind jarrettmeyer.com.";

const eliLillyHireDate = new Date("2018-09-10");
const yearsAtLilly = Math.round(
  (Date.now() - eliLillyHireDate.getTime()) / MS_PER_YEAR,
);
---

<Layout title="About" description={ABOUT_DESCRIPTION}>
  <h1>About</h1>

  <section>
    <p>
      I'm Jarrett Meyer, an Advisor in Machine Learning Engineering at Eli
      Lilly, where I've spent the last {yearsAtLilly} years working at the intersection
      of data, infrastructure, and the decisions they inform. Before that, I spent
      fifteen years building enterprise software. I've been writing code professionally
      since 2001.
    </p>
  </section>

  <section>
    <h2>The Long Version</h2>
    <p>
      I started in enterprise .NET and C#. Application development, solutions
      architecture, business intelligence. Domain driven design. Clean code.
      Test-driven development. Agile. SQL Server was the center of gravity, and
      the problems were about getting the right data to the right people in a
      format they could act on. I did that for about fifteen years.
    </p>
    <p>
      In 2018 I joined Eli Lilly's Decision Analytics and Optimization team. I
      started with data visualizations. D3.js, Spotfire, the kind of work where
      you're translating complex datasets into something a human can reason
      about. That led into machine learning engineering, and now into advisory
      work around AI and ML strategy. The throughline across all of it: finding
      the right tool for the problem at hand.
    </p>
  </section>

  <section>
    <h2>Outside of Work</h2>
    <p>
      Husband and father. Voracious reader. Caffeine enthusiast. Bourbon
      enjoyer.
    </p>
  </section>

  <section>
    <h2>About This Site</h2>
    <p>
      Built with <a href="https://astro.build/" target="_blank">Astro</a>. Icons
      by <a href="https://lucide.dev/" target="_blank">Lucide</a>. Hosted on <a
        href="https://docs.github.com/en/pages"
        target="_blank">GitHub Pages</a
      >.
    </p>
  </section>
</Layout>

<style>
  section + section {
    margin-top: 2em;
  }
</style>
