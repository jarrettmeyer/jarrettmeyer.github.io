---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Hello, I'm Jarrett!</h1>
			<h2>Senior Machine Learning Architect and Technology Strategy Leader</h2>
			<p>
			    Over 20 years of experience driving transformational software and data
				solutions. Expertise in AWS cloud infrastructure, machine learning
				engineering, and delivering scalable data solutions.
			</p>
		</main>
		<Footer />
	</body>
</html>
