{
  "name": "jarrettmeyer-github-io",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "astro": "astro",
    "astro:build": "astro build",
    "astro:dev": "astro dev",
    "astro:preview": "astro preview",
    "build": "bun run astro:build && bun run pagefind && bun run copy-404",
    "copy-404": "( [ -f dist/404.html ] || ( [ -f dist/404/index.html ] && cp dist/404/index.html dist/404.html ) )",
    "dev": "bun run astro:dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pagefind": "pagefind --site dist",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.1",
    "@astrojs/sitemap": "^3.7.1",
    "@pagefind/default-ui": "^1.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.0.8",
    "astro-expressive-code": "^0.41.7",
    "astro-pagefind": "^1.8.5",
    "d3": "^7.9.0",
    "pagefind": "^1.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@astrojs/mdx": "^5.0.2",
    "@types/d3": "^7.4.3",
    "@types/topojson-client": "^3.1.5",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
